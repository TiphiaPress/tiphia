    {
      "name": "06 Settings Users Plugins",
      "item": [
        {
          "name": "Get Settings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/settings",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "settings"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('settings are readable', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().title).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Settings",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Tiphia Postman\",\n  \"description\": \"A Rust blog powered by Tiphia.\",\n  \"base_url\": \"http://127.0.0.1:3000\",\n  \"timezone\": \"UTC\",\n  \"default_page_size\": 20,\n  \"comments_enabled\": true,\n  \"comment_moderation\": true,\n  \"permalink_format\": \"/posts/{slug}\",\n  \"seo\": {\n    \"meta_title_suffix\": \"Tiphia\",\n    \"meta_description\": \"A Rust blog powered by Tiphia.\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/settings",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "settings"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('settings are updated', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().title).to.eql('Tiphia Postman');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/users?page=1&per_page=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "users"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per_page",
                  "value": "10"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin can list users', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Plugins",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/plugins",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "plugins"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('plugins are listed', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Plugin Admin Menu",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/plugins/admin-menu",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "plugins",
                "admin-menu"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin menu is available', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Audit Plugin Config",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/plugins/{{plugin_name}}/config",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "plugins",
                "{{plugin_name}}",
                "config"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('plugin config is available or plugin is not installed', () => {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Audit Events",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/audit/events?page=1&per_page=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "audit",
                "events"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per_page",
                  "value": "10"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('audit events endpoint works when audit plugin is installed', () => {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "  if (pm.response.code === 200) {",
                  "    pm.expect(pm.response.json().data).to.be.an('array');",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
