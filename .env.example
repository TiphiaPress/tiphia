TIPHIA_CONFIG=tiphia.toml
TIPHIA_ENV=development
TIPHIA_BIND=127.0.0.1:3000
TIPHIA_REQUEST_TIMEOUT_SECS=30
TIPHIA_MAX_BODY_BYTES=1048576

DATABASE_URL=sqlite://tiphia.db?mode=rwc
TIPHIA_DB_MAX_CONNECTIONS=16
TIPHIA_DB_MIN_CONNECTIONS=1
TIPHIA_DB_CONNECT_TIMEOUT_SECS=10
TIPHIA_DB_ACQUIRE_TIMEOUT_SECS=10

RUST_LOG=tiphia=info,tower_http=info
TIPHIA_LOG_DIR=logs
TIPHIA_LOG_PREFIX=tiphia
TIPHIA_LOG_JSON=true

TIPHIA_JWT_SECRET=change-me-before-production-this-is-development-only
TIPHIA_TOKEN_TTL_SECONDS=604800

TIPHIA_CORS_ALLOWED_ORIGINS=
TIPHIA_REDIS_URL=
TIPHIA_RATE_LIMIT_LOGIN_PER_MINUTE=5
TIPHIA_RATE_LIMIT_COMMENTS_PER_MINUTE=10
